  <style>
    body{background:#070a12;color:#e5e7eb;}
    .glass{background:rgba(10,14,28,.62);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px)}
    .hero-card{position:relative;overflow:hidden;border:1px solid rgba(168,85,247,.18);box-shadow:0 24px 70px rgba(0,0,0,.62),0 0 0 1px rgba(168,85,247,.22) inset,0 0 42px rgba(168,85,247,.18)}
    /* Keep this pill GREEN across all roles */
    .trust-pill{background:linear-gradient(180deg, rgba(16,185,129,.18), rgba(16,185,129,.08)) !important;border:1px solid rgba(16,185,129,.38) !important;color:#b7f7de;box-shadow:0 10px 24px rgba(0,0,0,.35),0 0 18px rgba(16,185,129,.18) !important}
    .trust-pill .dot{width:.55rem;height:.55rem;border-radius:999px;background:rgba(16,185,129,.98) !important;box-shadow:0 0 18px rgba(16,185,129,.55) !important}

    /* Reduce border flicker on desktop by avoiding heavy blur/glow on the frame edge */
    .media-frame{aspect-ratio:16/9;border-radius:1.25rem;border:1px solid rgba(168,85,247,.42);background:rgba(255,255,255,.04);overflow:hidden;
      box-shadow:0 16px 44px rgba(0,0,0,.58),0 0 0 1px rgba(168,85,247,.18) inset,0 0 18px rgba(168,85,247,.14);
      background-clip:padding-box}
    .media-frame video,.media-frame img{width:100%;height:100%;object-fit:cover;display:block;backface-visibility:hidden}
    .cat-grid{display:grid;grid-template-columns:repeat(1,minmax(0,1fr));gap:12px;}
    @media (min-width:640px){.cat-grid{grid-template-columns:repeat(2,minmax(0,1fr));}}
    @media (min-width:1024px){.cat-grid{grid-template-columns:repeat(3,minmax(0,1fr));}}
    @media (min-width:1280px){.cat-grid{grid-template-columns:repeat(4,minmax(0,1fr));}}
  
    .hero-card::before{content:"";position:absolute;inset:-2px;background:
      radial-gradient(900px 420px at 12% 15%, rgba(168,85,247,.35), transparent 55%),
      radial-gradient(700px 380px at 85% 30%, rgba(99,102,241,.26), transparent 58%),
      radial-gradient(900px 520px at 50% 120%, rgba(168,85,247,.18), transparent 60%);
      opacity:.9;pointer-events:none}
    .hero-card > *{position:relative;z-index:1}
    /* Force a premium purple gradient even if other button styles exist */
    .btn-cta{background:linear-gradient(135deg, rgba(168,85,247,.95), rgba(99,102,241,.90)) !important;
      color:#fff !important;
      border:1px solid rgba(255,255,255,.18);
      box-shadow:0 16px 44px rgba(168,85,247,.30),0 0 0 1px rgba(168,85,247,.22) inset,0 0 26px rgba(99,102,241,.22);
      transition:transform .18s ease, filter .18s ease, box-shadow .18s ease}
    .btn-cta:hover{transform:translateY(-1px);filter:brightness(1.06);
      box-shadow:0 20px 58px rgba(168,85,247,.34),0 0 0 1px rgba(168,85,247,.24) inset,0 0 34px rgba(99,102,241,.24)}
    .btn-cta:active{transform:translateY(0px);filter:brightness(1.02)}
    .btn-cta:focus-visible{outline:none;box-shadow:0 0 0 3px rgba(168,85,247,.35),0 16px 44px rgba(168,85,247,.30),0 0 0 1px rgba(168,85,247,.22) inset}
    @media (prefers-reduced-motion: reduce){
      .btn-cta{transition:none}
      .btn-cta:hover,.btn-cta:active{transform:none}
    }


    /* Products + Benefits: glassmorphism + purple glow (matches hero language) */
